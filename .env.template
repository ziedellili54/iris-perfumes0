# 🔐 Firebase Configuration Template
# 
# INSTRUCTIONS:
# 1. Copy this file and rename it to ".env"
# 2. Replace all values with your actual Firebase credentials
# 3. NEVER commit the .env file to Git!
# 
# Get your credentials from:
# https://console.firebase.google.com/project/YOUR_PROJECT/settings/general

# Firebase Project Configuration
FIREBASE_API_KEY=your_api_key_here
FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
FIREBASE_APP_ID=your_app_id

# GitHub Configuration (for deployment)
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO=username/repository-name
GITHUB_BRANCH=main

# Admin Configuration
# NOTE: Don't store actual passwords here. Use Firebase Console to create admin.
ADMIN_EMAIL=admin@irisperfumes.com

# Application URLs
PRODUCTION_URL=https://yourusername.github.io/your-repo
DEVELOPMENT_URL=http://localhost:3000

# Optional: Google OAuth Client ID (if different from Firebase default)
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
